# Groq API key — free tier at https://console.groq.com (no credit card required)
# When set, llama-3.3-70b-versatile is used as the default LLM.
GROQ_API_KEY=your_groq_api_key_here

# Ollama base URL (only needed if using local Ollama as fallback)
OLLAMA_BASE_URL=http://localhost:11434

CHROMA_PERSIST_DIR=./chroma_store
# When running locally (from backend/): ../data  |  In Docker: ./data (mounted via docker-compose)
DATA_DIR=../data
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=600
CHUNK_OVERLAP=80
RETRIEVAL_K=4
CORS_ORIGINS=["http://localhost:3000"]
